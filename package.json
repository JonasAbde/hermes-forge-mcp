{
  "name": "forge-mcp",
  "version": "2.2.0",
  "description": "MCP server for the Hermes Forge platform — discover, open, chat with, fuse, and deploy AI Agent Packs via the Model Context Protocol",
  "type": "module",
  "main": "build/http-server.js",
  "types": "build/http-server.d.ts",
  "files": [
    "build/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JonasAbde/hermes-forge-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/JonasAbde/hermes-forge-mcp/issues"
  },
  "homepage": "https://github.com/JonasAbde/hermes-forge-mcp#readme",
  "scripts": {
    "build": "tsc",
    "start": "node build/http-server.js",
    "start:stdio": "node build/index.js",
    "dev": "tsx src/http-server.ts",
    "dev:stdio": "tsx src/index.ts",
    "prepare": "npm run build",
    "lint": "eslint src/",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "test": "npm run smoke && node --test tests/test-auth.mjs tests/test-resilience.mjs && node tests/test-http.mjs",
    "smoke": "node tests/smoke.mjs"
  },
  "keywords": [
    "mcp",
    "forge",
    "ai-agents",
    "model-context-protocol",
    "hermes-forge",
    "agent-packs"
  ],
  "author": "JonasAbde",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express-rate-limit": "^8.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
