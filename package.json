{
  "name": "forge-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Hermes Forge platform — discover, open, chat with, fuse, and deploy AI Agent Packs via the Model Context Protocol",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "test": "node --test tests/",
    "smoke": "node tests/smoke.mjs"
  },
  "keywords": ["mcp", "forge", "ai-agents", "model-context-protocol", "hermes-forge"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
