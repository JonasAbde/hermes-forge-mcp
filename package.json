{
  "name": "forge-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Hermes Forge platform — discover, open, chat with, fuse, and deploy AI Agent Packs via the Model Context Protocol",
  "type": "module",
  "main": "build/http-server.js",
  "scripts": {
    "build": "tsc",
    "start": "node build/http-server.js",
    "start:stdio": "node build/index.js",
    "dev": "tsx src/http-server.ts",
    "dev:stdio": "tsx src/index.ts",
    "prepare": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "test": "npm run smoke && node --test tests/test-auth.mjs tests/test-resilience.mjs",
    "smoke": "node tests/smoke.mjs"
  },
  "keywords": [
    "mcp",
    "forge",
    "ai-agents",
    "model-context-protocol",
    "hermes-forge"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
