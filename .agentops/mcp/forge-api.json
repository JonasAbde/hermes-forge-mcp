{
  "name": "forge-api",
  "description": "MCP connection to the main Hermes Forge API (forge.tekup.dk)",
  "transport": {
    "type": "http",
    "baseUrl": "https://forge.tekup.dk/api/forge/v1",
    "headers": {
      "Authorization": "Bearer ${FORGE_API_TOKEN}",
      "Content-Type": "application/json"
    }
  },
  "tools": {
    "namespace": "forge",
    "discover": true
  },
  "rateLimit": {
    "maxRequests": 100,
    "windowMs": 60000
  }
}
