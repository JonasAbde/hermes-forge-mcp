# Forge MCP — Configuration
# Copy this to .env or pass as environment variables to your MCP client.

# Hermes Forge API base URL (default: https://forge.tekup.dk/api/forge)
FORGE_API_BASE_URL=https://forge.tekup.dk/api/forge

# Authentication — use one of the following:
# Option 1: Personal Access Token (recommended for programmatic access)
# Generate at: https://forge.tekup.dk/account
FORGE_PAT=hfp_your_pat_here

# Option 2: API Key
# FORGE_API_KEY=forge_key_your_api_key_here

# Option 3: Email-based magic link auth
# Set your email, then use the get_magic_link tool to receive a login link.
# FORGE_EMAIL=user@example.com

# Optional: extra JSON headers for the Forge API
# FORGE_EXTRA_HEADERS={"X-Custom":"value"}
