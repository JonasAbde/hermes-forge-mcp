# Hermes Forge MCP Server Configuration
# Copy this to forge.env and fill in your values

# Hermes Forge API base URL
FORGE_API_BASE_URL=https://forge.tekup.dk/api/forge

# Authentication — use one of the following:
# Option 1: Personal Access Token (PAT) from forge.tekup.dk/account
FORGE_PAT=hfp_your_pat_here

# Option 2: API Key from forge.tekup.dk/account
FORGE_API_KEY=forge_key_your_api_key_here

# Magic Link Auth (for email-based login)
# Set your email, then use the get_magic_link tool
FORGE_EMAIL=user@example.com

# Optional: Custom headers for the Forge API
# FORGE_EXTRA_HEADERS={"X-Custom":"value"}
